<Window x:Class="Dota1Warkey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Dota1 Warkey"
        Height="500" Width="640"
        MinHeight="460" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource AppBg}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>   <!-- title bar -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Title bar ── -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2"
              Background="{StaticResource SidebarBg}">
            <!-- Draggable region (full title bar) -->
            <TextBlock Text="Dota1 Warkey"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="12"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Window control buttons (right side) -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                <Button Content="─"
                        Width="28" Height="28"
                        FontSize="10"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        BorderThickness="0"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="MinimizeBtn_Click"
                        Cursor="Hand"/>
                <Button Content="✕"
                        Width="28" Height="28"
                        FontSize="10"
                        Foreground="{StaticResource TextSecondary}"
                        Background="Transparent"
                        BorderThickness="0"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="CloseBtn_Click"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- ── Sidebar ── -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{StaticResource SidebarBg}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="1"
                                  Color="Black" Opacity="0.3"
                                  Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status -->
                <StackPanel Margin="16,16,16,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot"
                                 Width="7" Height="7"
                                 Fill="#FF3B30"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText"
                                   Text="未检测到 War3"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                           Fill="{StaticResource Separator}" Margin="12,0"/>

                <!-- Nav items -->
                <StackPanel Grid.Row="1" Margin="8,8">
                    <Button Style="{StaticResource NavButton}"
                            Tag="Warkey"
                            Name="BtnWarkey"
                            Click="Nav_Click">
                        <TextBlock Text="改键"/>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Tag="Settings"
                            Name="BtnSettings"
                            Click="Nav_Click"
                            Margin="0,2,0,0">
                        <TextBlock Text="设置"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Content ── -->
        <Frame Grid.Row="1" Grid.Column="1"
               Name="NavFrame"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource AppBg}"/>
    </Grid>
</Window>
