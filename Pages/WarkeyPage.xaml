<Page x:Class="Dota1Warkey.Pages.WarkeyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:Dota1Warkey.Converters"
      Background="{StaticResource AppBg}"
      Title="Warkey">
    <Page.Resources>
        <converters:HotkeyToStringConverter x:Key="HotkeyToString"/>

        <!-- Card border: default state -->
        <Style x:Key="SlotCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Height"          Value="80"/>
            <Setter Property="Margin"          Value="5"/>
        </Style>

        <!-- Position label (top-left) -->
        <Style x:Key="PosLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontFamily"  Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="Margin"      Value="10,8,0,0"/>
            <Setter Property="VerticalAlignment"   Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- NumPad hint (top-right) -->
        <Style x:Key="NumLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#44FFFFFF"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontFamily"  Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="Margin"      Value="0,8,10,0"/>
            <Setter Property="VerticalAlignment"   Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Section title ── -->
        <TextBlock Grid.Row="0"
                   Text="物品栏"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   FontFamily="Segoe UI Variable Text, Segoe UI"
                   Margin="29,16,0,8"/>

        <!-- ── 2 × 3 Slot grid ── -->
        <Grid Grid.Row="1" Margin="24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Slot 1 ── 左上 / Num 7 -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SlotCard}"
                    x:Name="Card1">
                <Grid>
                    <TextBlock Style="{StaticResource PosLabel}" Text="左上"/>
                    <TextBlock Style="{StaticResource NumLabel}"  Text="Num 7"/>
                    <TextBox Style="{StaticResource SlotTextBox}"
                             Text="{Binding Slot1, Converter={StaticResource HotkeyToString}, Mode=OneWay}"
                             Tag="Slot1" KeyDown="Slot_KeyDown"
                             GotFocus="Slot_GotFocus" LostFocus="Slot_LostFocus"/>
                </Grid>
            </Border>

            <!-- Slot 2 ── 右上 / Num 8 -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SlotCard}"
                    x:Name="Card2">
                <Grid>
                    <TextBlock Style="{StaticResource PosLabel}" Text="右上"/>
                    <TextBlock Style="{StaticResource NumLabel}"  Text="Num 8"/>
                    <TextBox Style="{StaticResource SlotTextBox}"
                             Text="{Binding Slot2, Converter={StaticResource HotkeyToString}, Mode=OneWay}"
                             Tag="Slot2" KeyDown="Slot_KeyDown"
                             GotFocus="Slot_GotFocus" LostFocus="Slot_LostFocus"/>
                </Grid>
            </Border>

            <!-- Slot 3 ── 左中 / Num 4 -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SlotCard}"
                    x:Name="Card3">
                <Grid>
                    <TextBlock Style="{StaticResource PosLabel}" Text="左中"/>
                    <TextBlock Style="{StaticResource NumLabel}"  Text="Num 4"/>
                    <TextBox Style="{StaticResource SlotTextBox}"
                             Text="{Binding Slot3, Converter={StaticResource HotkeyToString}, Mode=OneWay}"
                             Tag="Slot3" KeyDown="Slot_KeyDown"
                             GotFocus="Slot_GotFocus" LostFocus="Slot_LostFocus"/>
                </Grid>
            </Border>

            <!-- Slot 4 ── 右中 / Num 5 -->
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SlotCard}"
                    x:Name="Card4">
                <Grid>
                    <TextBlock Style="{StaticResource PosLabel}" Text="右中"/>
                    <TextBlock Style="{StaticResource NumLabel}"  Text="Num 5"/>
                    <TextBox Style="{StaticResource SlotTextBox}"
                             Text="{Binding Slot4, Converter={StaticResource HotkeyToString}, Mode=OneWay}"
                             Tag="Slot4" KeyDown="Slot_KeyDown"
                             GotFocus="Slot_GotFocus" LostFocus="Slot_LostFocus"/>
                </Grid>
            </Border>

            <!-- Slot 5 ── 左下 / Num 1 -->
            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SlotCard}"
                    x:Name="Card5">
                <Grid>
                    <TextBlock Style="{StaticResource PosLabel}" Text="左下"/>
                    <TextBlock Style="{StaticResource NumLabel}"  Text="Num 1"/>
                    <TextBox Style="{StaticResource SlotTextBox}"
                             Text="{Binding Slot5, Converter={StaticResource HotkeyToString}, Mode=OneWay}"
                             Tag="Slot5" KeyDown="Slot_KeyDown"
                             GotFocus="Slot_GotFocus" LostFocus="Slot_LostFocus"/>
                </Grid>
            </Border>

            <!-- Slot 6 ── 右下 / Num 2 -->
            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource SlotCard}"
                    x:Name="Card6">
                <Grid>
                    <TextBlock Style="{StaticResource PosLabel}" Text="右下"/>
                    <TextBlock Style="{StaticResource NumLabel}"  Text="Num 2"/>
                    <TextBox Style="{StaticResource SlotTextBox}"
                             Text="{Binding Slot6, Converter={StaticResource HotkeyToString}, Mode=OneWay}"
                             Tag="Slot6" KeyDown="Slot_KeyDown"
                             GotFocus="Slot_GotFocus" LostFocus="Slot_LostFocus"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Hint ── -->
        <TextBlock Grid.Row="2"
                   Text="点击卡片后按键绑定  ·  Alt + 键  ·  Esc 清除"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   FontFamily="Segoe UI Variable Text, Segoe UI"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,16"/>
    </Grid>
</Page>
